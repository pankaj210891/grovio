# Backend API base URL — used for all storefront API calls.
# Default when unset: http://localhost:3001 (matches apps/api PORT=3001, no /api prefix).
# Do NOT put secrets in VITE_* variables — they are bundled into the client.
VITE_API_URL=http://localhost:3001

# Public CDN / media URL — used for product images and uploaded assets
# (e.g., https://cdn.yourdomain.com or your S3 bucket public URL)
VITE_PUBLIC_URL=http://localhost:3001

# Google Maps / Places API key — required for checkout address autocomplete (Phase 4+)
# Obtain from Google Cloud Console: https://console.cloud.google.com/
# Restrict this key to your storefront domain in production
VITE_GOOGLE_MAPS_API_KEY=
