# Backend API base URL — used for all admin panel API calls.
# Use a relative path to go through the Vite dev proxy (recommended for local dev).
# The proxy in vite.config.ts forwards /api → http://localhost:3001 and strips the prefix.
VITE_API_BASE_URL=/api

# Internal admin token — must match INTERNAL_ADMIN_TOKEN in apps/api/.env
# Phase 4 replaces this with JWT auth (jose library).
# Do NOT put real secrets in VITE_* variables in production — they are bundled into the client.
VITE_INTERNAL_ADMIN_TOKEN=<your INTERNAL_ADMIN_TOKEN from apps/api/.env>
