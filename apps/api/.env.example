# ============================================================
# Grovio API — Environment Variables
# Copy this file to .env and fill in values before starting.
# All variables without defaults are REQUIRED.
# ============================================================

# Application environment.
# One of: development | test | production
NODE_ENV=development

# Port the HTTP server listens on.
# Override to run multiple API instances side-by-side.
PORT=3001

# PostgreSQL connection string (REQUIRED).
# Format: postgresql://USER:PASSWORD@ep-xxx-pooler.neon.tech/DATABASE?sslmode=require
# Obtain: neon.com → New Project → Connection Details → Pooled connection string.
# SSL is auto-detected from URL — no extra config needed.
DATABASE_URL=postgresql://user:pass@ep-cool-name-123456-pooler.neon.tech/grovio?sslmode=require

# PostgreSQL direct (non-pooled) connection string — used ONLY by drizzle-kit migrations.
# Format: postgresql://USER:PASSWORD@ep-xxx.neon.tech/DATABASE  (no -pooler in hostname)
# Only required when running: pnpm db:migrate  or  pnpm db:generate
DATABASE_DIRECT_URL=postgresql://user:pass@ep-cool-name-123456.neon.tech/grovio?sslmode=require

# Redis connection string (REQUIRED).
# Format: rediss://:TOKEN@HOST:PORT  (Upstash uses rediss:// — TLS enforced)
# Obtain: upstash.com → New Database → Details → ioredis connection string.
# TLS is auto-detected — no extra config needed.
# Note: Use a Fixed plan for environments running BullMQ workers to avoid per-command billing.
REDIS_URL=rediss://:your-upstash-token@your-db.upstash.io:6380

# JWT signing secret for HS256 tokens (REQUIRED — min 32 chars).
# Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never share this value or reuse it across environments.
JWT_SECRET=replace-with-a-secure-random-string-of-at-least-32-chars

# Feature flag cache TTL in seconds (Redis).
# Controls how quickly feature flag changes propagate after an admin update.
# Lower values mean faster propagation at the cost of more DB reads.
# Architecture decision D-05: feature flags are DB-backed + Redis-cached; never hot-path DB.
FEATURE_FLAG_TTL_SECONDS=60

# OpenSearch / Bonsai endpoint URL (OPTIONAL until Phase 3).
# Format: https://USER:PASSWORD@CLUSTER.bonsai.io
# Obtain: bonsai.io → New Cluster (Sandbox free tier) → Access → Credentials.
# Required from Phase 3 (Catalog & Search) onwards.
OPENSEARCH_URL=https://your-user:your-pass@your-cluster.bonsai.io

# Redis cache TTL in seconds for the category tree key (OPTIONAL — has default).
# Safety-net TTL — CategoryService uses write-through invalidation so changes
# propagate immediately; this TTL is the backstop if invalidation is missed.
CATEGORY_TREE_TTL_SECONDS=300

# Google SMTP credentials (required when email sending is enabled — Phase 8+).
# Use a Gmail App Password (not your account password): myaccount.google.com/apppasswords
GOOGLE_SMTP_USER=your-gmail-address@gmail.com
GOOGLE_SMTP_PASS=your-16-character-gmail-app-password

# Google Maps / Places API key (required Phase 4+ for checkout address autocomplete).
# Obtain: console.cloud.google.com → APIs & Services → Credentials → Create key
# Enable: Maps JavaScript API + Places API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# =============================================================
# Phase 5: Commerce Core — Payment Provider credentials (OPTIONAL)
# Leave empty to boot the API without payment support.
# Only one provider is required; both can be enabled simultaneously.
# =============================================================

# --- Stripe ---
# Obtain: dashboard.stripe.com → Developers → API Keys
# Use test mode keys (sk_test_...) for development/staging.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# Stripe publishable key — sent to the frontend for Stripe.js/Elements initialization.
# Obtain: dashboard.stripe.com → Developers → API Keys (Publishable key)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key-here

# Stripe webhook secret — used to verify webhook signature (PAY-03, D-10).
# Obtain: dashboard.stripe.com → Developers → Webhooks → endpoint → Signing secret
# For local dev: stripe listen --forward-to localhost:3001/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# --- Razorpay ---
# Obtain: dashboard.razorpay.com → Settings → API Keys → Generate Key
# Use test mode keys for development.
RAZORPAY_KEY_ID=rzp_test_your-razorpay-key-id-here

# Razorpay key secret — used for order creation and webhook HMAC verification.
# Never expose this to the frontend.
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here

# Razorpay webhook secret — used to verify webhook HMAC signature (PAY-03, D-10).
# Obtain: dashboard.razorpay.com → Settings → Webhooks → endpoint → Secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# --- Inventory Reservation TTL ---
# Time in minutes before an inventory reservation is released (D-07).
# BullMQ ReleaseReservationJob fires after this delay if payment is not received.
# Default: 15 minutes. Adjust based on expected payment completion time.
RESERVATION_TTL_MINUTES=15

# =============================================================
# Phase 11: S3-compatible file storage (KYC documents, vendor assets)
# Leave empty to boot the API without file upload support.
# Supports Cloudflare R2, Supabase Storage, or any S3-compatible provider.
# =============================================================

# S3-compatible endpoint URL.
# Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Bucket name for uploads.
STORAGE_BUCKET=grovio-uploads

# Access key ID (from your provider dashboard).
STORAGE_ACCESS_KEY=your-storage-access-key-id

# Secret access key (never commit to version control).
STORAGE_SECRET_KEY=your-storage-secret-access-key

# Public base URL for uploaded files.
STORAGE_PUBLIC_URL=https://pub-your-r2-public-url.r2.dev

# AWS region (default: 'auto' for Cloudflare R2).
STORAGE_REGION=auto
