# Backend API base URL — used for all vendor panel API calls (e.g., http://localhost:3000/api)
# Do NOT put secrets in VITE_* variables — they are bundled into the client
VITE_API_URL=http://localhost:3000/api

# Public CDN / media URL — used for product images and uploaded assets
# (e.g., https://cdn.yourdomain.com or your S3 bucket public URL)
VITE_PUBLIC_URL=http://localhost:3000
