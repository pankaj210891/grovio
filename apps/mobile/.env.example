# Backend API base URL — the URL of the Grovio API server (e.g. https://api.yourdomain.com)
# For local development use: http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google Places API key — required for address autocomplete in checkout flow (Phase 7)
# Obtain from: https://console.cloud.google.com/apis/credentials
# Enable the "Places API" and "Geocoding API" for your project
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_places_api_key_here
