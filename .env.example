# =============================================================
# Grovio — Root Environment Variables
# Copy this file to .env and fill in your values.
# These are shared infrastructure variables used by apps/api.
# Per-app variables are in apps/{app-name}/.env.example
# =============================================================

# =============================================================
# Node Environment
# =============================================================
# Controls logging verbosity, error detail, and feature behaviour.
# Values: development | test | production
NODE_ENV=development

# =============================================================
# Database
# =============================================================
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev: use docker-compose.yml credentials (grovio/grovio).
# Production: use a managed service (Supabase, Railway, Neon, etc.).
DATABASE_URL=postgresql://grovio:grovio@localhost:5432/grovio

# =============================================================
# Redis
# =============================================================
# Redis connection string.
# Format: redis://HOST:PORT  or  redis://:PASSWORD@HOST:PORT (authenticated)
# Local dev: use docker-compose.yml.
# Production: Upstash Redis or a managed Redis service.
REDIS_URL=redis://localhost:6379

# =============================================================
# Authentication
# =============================================================
# Secret key for HS256 JWT signing and verification.
# Must be at least 32 characters. Never commit your real secret.
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-character-random-secret-string

# =============================================================
# Feature Flags
# =============================================================
# Redis cache TTL for feature flag values (in seconds).
# Controls how quickly a database flag toggle is reflected in API responses.
# Lower = faster propagation but higher DB query rate. Default: 60 seconds.
FEATURE_FLAG_TTL_SECONDS=60

# =============================================================
# Google SMTP (Transactional Email)
# =============================================================
# Gmail address used as the SMTP sender for all transactional email.
# Must be a Google Workspace or Gmail account with SMTP access enabled.
GOOGLE_SMTP_USER=your-gmail-address@gmail.com

# Gmail App Password (not your account login password).
# Requires 2-Factor Authentication on the Google account.
# Generate at: https://myaccount.google.com/apppasswords
GOOGLE_SMTP_PASS=your-16-character-gmail-app-password

# =============================================================
# OpenSearch
# =============================================================
# OpenSearch endpoint URL.
# Local dev: use docker-compose.yml (http://localhost:9200).
# Production: managed OpenSearch/Elasticsearch service.
# Required from Phase 3 (Catalog & Search) onwards.
OPENSEARCH_URL=http://localhost:9200

# =============================================================
# Google Maps / Places
# =============================================================
# Google Maps Platform API key.
# Required for Google Places autocomplete in checkout and address management (Phase 4+).
# Obtain: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API, Places API (New).
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# =============================================================
# Backend Port
# =============================================================
# HTTP port for the Fastify backend API. Default: 3001.
# Per-app Vite dev ports are set in each app's .env.example.
PORT=3001
