# Dependencies
node_modules

# Build outputs
dist
build
.next
out

# Turborepo
.turbo

# Environment files
.env
.env.local
.env.*.local

# Test coverage
coverage

# TypeScript build info
*.tsbuildinfo

# TypeScript compiled output emitted in-place by tsc -b (web apps have no outDir).
# Vite reads .tsx/.ts directly; these are build artifacts, not source files.
apps/web-storefront/src/**/*.js
apps/web-storefront/src/**/*.js.map
apps/web-storefront/src/**/*.d.ts
apps/web-storefront/src/**/*.d.ts.map
apps/web-vendor/src/**/*.js
apps/web-vendor/src/**/*.js.map
apps/web-vendor/src/**/*.d.ts
apps/web-vendor/src/**/*.d.ts.map
apps/web-admin/src/**/*.js
apps/web-admin/src/**/*.js.map
apps/web-admin/src/**/*.d.ts
apps/web-admin/src/**/*.d.ts.map

# OS artifacts
.DS_Store
Thumbs.db

# Editor directories and files
.idea
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# React Native / Expo
apps/mobile/.expo
apps/mobile/android
apps/mobile/ios/Pods
apps/mobile/ios/build
# Keep tracked iOS config files (e.g., Podfile, Info.plist) via negation rules
!apps/mobile/ios/Podfile
!apps/mobile/ios/Podfile.lock

# pnpm
pnpm-debug.log*

# Logs
*.log
logs

# Claude Code
.claude/settings.local.json
.claude/worktrees/

# Dev debug scripts (Windows batch/node scripts from local debugging sessions)
*.bat
check_*.js
nodecheck.js
test_import*.mjs
resolve_vitest*.bat
cookies.txt

# Storybook build output
storybook-static/
